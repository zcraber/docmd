{
  "name": "@docmd/live",
  "version": "0.5.1",
  "description": "Browser-based editor engine for docmd.",
  "bin": {
    "docmd-live": "bin/docmd-live.js"
  },
  "scripts": {
    "build": "node -e \"require('./src/build.js').build()\""
  },
  "files": [
    "bin",
    "src",
    "dist",
    "index.js",
    "src/build.js"
  ],
  "dependencies": {
